        "east": "true"
      },
      "apply": {
        "model": "mirage2004:block/security_grille_gray_cap_arm_bottom",
        "y": 90
      }
    },
    {
      "when": {
        "bottom": "true",
        "south": "true"
      },
      "apply": {
        "model": "mirage2004:block/security_grille_gray_cap_arm_bottom",
        "y": 180
      }
    },
