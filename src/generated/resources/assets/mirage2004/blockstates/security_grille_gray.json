{
  "multipart": [
    {
      "apply": {
        "model": "mirage2004:block/security_grille_gray_post"
      }
    },
    {
      "when": {
        "north": "true"
      },
      "apply": {
        "model": "mirage2004:block/security_grille_gray_side"
      }
    },
    {
      "when": {
        "east": "true"
      },
      "apply": {
        "model": "mirage2004:block/security_grille_gray_side",
        "y": 90
      }
    },
    {
      "when": {
        "south": "true"
      },
      "apply": {
        "model": "mirage2004:block/security_grille_gray_side_alt"
      }
    },
    {
      "when": {
        "west": "true"
      },
      "apply": {
        "model": "mirage2004:block/security_grille_gray_side_alt",
        "y": 90
      }
    },
    {
      "when": {
        "north": "false"
      },
      "apply": {
        "model": "mirage2004:block/security_grille_gray_noside"
      }
    },
    {
      "when": {
        "east": "false"
      },
      "apply": {
        "model": "mirage2004:block/security_grille_gray_noside_alt"
      }
    },
    {
      "when": {
        "south": "false"
      },
      "apply": {
        "model": "mirage2004:block/security_grille_gray_noside_alt",
