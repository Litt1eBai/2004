      },
      "apply": {
        "model": "mirage2004:block/security_grille_gray_cap_arm_top"
      }
    },
    {
      "when": {
        "top": "true",
        "east": "true"
      },
      "apply": {
        "model": "mirage2004:block/security_grille_gray_cap_arm_top",
        "y": 90
